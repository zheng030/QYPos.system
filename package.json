{
  "name": "qypos-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "audit:build-safety": "node scripts/audit-build-safety.mjs",
    "build:verify": "npm run build && npm run audit:build-safety",
    "preview": "vite preview",
    "audit:runtime": "node scripts/audit-runtime-refactor.mjs",
    "audit:styles": "node scripts/audit-style-contracts.mjs",
    "audit:ui-parity": "node scripts/audit-ui-parity.mjs",
    "migrate:rtdb:v3": "node scripts/migrate-rtdb-v3.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run typecheck && npm run lint && npm run audit:runtime && npm run audit:styles && npm run audit:ui-parity && npm test && npm run build:verify",
    "test": "TZ=Asia/Taipei vitest run"
  },
  "dependencies": {
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "firebase": "^12.13.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.10.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
